# =============================================================================
# Northflow PSE — Environment Configuration
# Copy this file to .env and fill in your credentials.
# .env is gitignored and must never be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://pse:password@localhost:5432/pse

# ---------------------------------------------------------------------------
# Zarr Array Store
# ---------------------------------------------------------------------------
ZARR_STORE_PATH=/data/zarr
# ZARR_STORE_URL=s3://your-bucket/zarr   # Uncomment for cloud-backed store

# ---------------------------------------------------------------------------
# ERA5 / Copernicus Climate Data Store
# Register at: https://cds.climate.copernicus.eu/
# ---------------------------------------------------------------------------
ERA5_CDS_API_KEY=

# ---------------------------------------------------------------------------
# Sentinel-2 / Copernicus Data Space Ecosystem
# Register at: https://dataspace.copernicus.eu/
# ---------------------------------------------------------------------------
COPERNICUS_DATASPACE_CLIENT_ID=
COPERNICUS_DATASPACE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-in-production
